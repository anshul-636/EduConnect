// Prisma Schema — EduConnect (v2 — full platform)
// Run `npm run db:push` after any changes.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  SCHOOL
  TEACHER
  STUDENT
}

enum EventStatus {
  DRAFT
  PUBLISHED
  OPEN
  ONGOING
  COMPLETED
}

enum EventCategory {
  DEBATE
  QUIZ
  SCIENCE
  SPORTS
  ARTS
  OTHER
}

enum ResourceType {
  PDF
  VIDEO
  LINK
  NOTES
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CertType {
  PARTICIPATION
  WINNER
  RUNNER_UP
}

enum BotType {
  RAG
  PLATFORM
}

enum NotificationType {
  EVENT_REGISTERED
  EVENT_REMINDER
  EVENT_RESULT
  CERTIFICATE_READY
  ASSIGNMENT_CREATED
  ASSIGNMENT_GRADED
  ANNOUNCEMENT
  FORUM_REPLY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  LATE
  RESUBMITTED
}

// ─── CORE MODELS ──────────────────────────────────────────────────────────────

model School {
  id          String    @id @default(uuid())
  name        String
  location    String?
  affiliation String?   // CBSE, ICSE, State Board
  logoUrl     String?
  createdAt   DateTime  @default(now())

  adminId      String?        @unique
  admin        User?          @relation("SchoolAdmin", fields: [adminId], references: [id])
  members      User[]         @relation("SchoolMembers")
  events       Event[]
  resources    Resource[]
  leaderboard  Leaderboard[]
  classes      Class[]
  announcements Announcement[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  isVerified Boolean @default(false)
  otps       OTP[]

  schoolId  String?
  school    School?  @relation("SchoolMembers", fields: [schoolId], references: [id])
  adminOf   School?  @relation("SchoolAdmin")

  // Event & learning
  registrations Registration[]
  resources     Resource[]
  leaderboard   Leaderboard[]
  certificates  Certificate[]
  chatSessions  ChatSession[]
  studyPlans    StudyPlan[]

  // Forum
  forumPosts    ForumPost[]
  forumLikes    ForumLike[]

  // Resource upvotes
  resourceUpvotes ResourceUpvote[]

  // Notifications
  notifications Notification[]

  // Classes (student enrolled in / teacher teaches)
  enrollments   ClassEnrollment[]
  teachingClasses Class[]         @relation("ClassTeacher")

  // Assignments
  createdAssignments Assignment[]   @relation("TeacherAssignments")
  submissions        Submission[]

  // Attendance
  attendanceRecords  Attendance[]   @relation("StudentAttendance")
  markedAttendances  Attendance[]   @relation("TeacherAttendance")

  // Timetable
  timetableSlots TimetableSlot[] @relation("TimetableTeacher")

  // Announcements
  announcements Announcement[]
}

// ─── EVENT MODELS ─────────────────────────────────────────────────────────────

model Event {
  id          String        @id @default(uuid())
  title       String
  description String
  targetClass String        @default("All")
  location    String        @default("TBA")
  eventTime   String        @default("TBA")
  prizePool   String        @default("None")
  firstPrize  String        @default("None")
  secondPrize String        @default("None")
  thirdPrize  String        @default("None")
  category    EventCategory @default(OTHER)
  eventDate   DateTime
  regDeadline DateTime?
  maxTeams    Int?
  teamSize    Int           @default(1)
  status      EventStatus   @default(DRAFT)
  subjectTags String[]
  answerKey   Json?         // [{question, answer, explanation}]
  createdAt   DateTime      @default(now())

  schoolId      String
  school        School        @relation(fields: [schoolId], references: [id])
  registrations Registration[]
  leaderboard   Leaderboard[]
  certificates  Certificate[]
  forumPosts    ForumPost[]
  studyPlans    StudyPlan[]
}

model Registration {
  id           String   @id @default(uuid())
  teamName     String?
  teamMembers  Json?    @default("[]")
  status       String   @default("REGISTERED")
  rank         Int?
  score        Float?
  answers      Json?    // [{question, answer}] — student's submitted answers
  registeredAt DateTime @default(now())

  eventId   String
  event     Event  @relation(fields: [eventId], references: [id])
  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentId])
}

// ─── RESOURCE MODELS ──────────────────────────────────────────────────────────

model Resource {
  id          String       @id @default(uuid())
  title       String
  description String?
  type        ResourceType @default(PDF)
  fileUrl     String?
  subject     String?
  topic       String?
  difficulty  Difficulty   @default(BEGINNER)
  upvotes     Int          @default(0)
  viewCount   Int          @default(0)
  isEmbedded  Boolean      @default(false)
  createdAt   DateTime     @default(now())

  schoolId   String?
  school     School?  @relation(fields: [schoolId], references: [id])
  uploadedBy String
  uploader   User     @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)

  chatSessions    ChatSession[]
  upvoteRecords   ResourceUpvote[]
  assignments     Assignment[]
}

// Tracks who upvoted what — prevents double-upvoting
model ResourceUpvote {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, resourceId])
}

// ─── LEADERBOARD & CERTIFICATES ───────────────────────────────────────────────

model Leaderboard {
  id        String   @id @default(uuid())
  score     Float
  rank      Int
  category  String?
  updatedAt DateTime @updatedAt

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId  String
  school    School @relation(fields: [schoolId], references: [id])
  eventId   String
  event     Event  @relation(fields: [eventId], references: [id])
}

model Certificate {
  id       String   @id @default(uuid())
  type     CertType
  fileUrl  String?
  issuedAt DateTime @default(now())

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event  @relation(fields: [eventId], references: [id])
}

// ─── FORUM MODELS ─────────────────────────────────────────────────────────────

model ForumPost {
  id          String    @id @default(uuid())
  title       String?
  content     String    // Stored as markdown
  isEdited    Boolean   @default(false)
  editedAt    DateTime?
  createdAt   DateTime  @default(now())

  eventId  String?
  event    Event?    @relation(fields: [eventId], references: [id])
  authorId String
  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId String?
  parent   ForumPost? @relation("Replies", fields: [parentId], references: [id])
  replies  ForumPost[] @relation("Replies")
  likes    ForumLike[]
}

model ForumLike {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([userId, postId])
}

// ─── NOTIFICATION MODELS ──────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  data      Json?            // { eventId?, certId?, assignmentId?, postId? }
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Announcement {
  id         String   @id @default(uuid())
  title      String
  content    String
  targetRole String   @default("ALL") // ALL | STUDENT | TEACHER
  createdAt  DateTime @default(now())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])
  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  classId  String?
  class    Class?  @relation(fields: [classId], references: [id])
}

// ─── CLASS & TIMETABLE MODELS ─────────────────────────────────────────────────

model Class {
  id        String   @id @default(uuid())
  name      String   // "Grade 10-A"
  grade     String   // "10"
  section   String   // "A"
  year      Int      // academic year e.g. 2025
  createdAt DateTime @default(now())

  schoolId  String
  school    School  @relation(fields: [schoolId], references: [id])
  teacherId String?
  teacher   User?   @relation("ClassTeacher", fields: [teacherId], references: [id])

  enrollments   ClassEnrollment[]
  assignments   Assignment[]
  attendances   Attendance[]
  timetableSlots TimetableSlot[]
  announcements Announcement[]

  @@unique([schoolId, grade, section, year])
}

model ClassEnrollment {
  id         String   @id @default(uuid())
  enrolledAt DateTime @default(now())

  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([userId, classId])
}

model TimetableSlot {
  id        String   @id @default(uuid())
  day       String   // MONDAY | TUESDAY | WEDNESDAY | THURSDAY | FRIDAY | SATURDAY
  startTime String   // "09:00"
  endTime   String   // "10:00"
  subject   String
  roomNo    String?
  createdAt DateTime @default(now())

  teacherId String
  teacher   User   @relation("TimetableTeacher", fields: [teacherId], references: [id])
  classId   String
  class     Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
}

// ─── ASSIGNMENT MODELS ────────────────────────────────────────────────────────

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String?
  instructions String? // Rich text/markdown
  dueDate     DateTime
  maxScore    Float    @default(100)
  allowLate   Boolean  @default(false)
  createdAt   DateTime @default(now())

  classId    String
  class      Class      @relation(fields: [classId], references: [id])
  teacherId  String
  teacher    User       @relation("TeacherAssignments", fields: [teacherId], references: [id])
  resourceId String?
  resource   Resource?  @relation(fields: [resourceId], references: [id])
  submissions Submission[]
}

model Submission {
  id          String           @id @default(uuid())
  content     String?          // text submission
  fileUrl     String?          // file submission
  score       Float?
  feedback    String?
  status      SubmissionStatus @default(SUBMITTED)
  submittedAt DateTime         @default(now())
  gradedAt    DateTime?

  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
}

// ─── ATTENDANCE MODEL ─────────────────────────────────────────────────────────

model Attendance {
  id        String           @id @default(uuid())
  date      DateTime         @db.Date
  status    AttendanceStatus
  note      String?
  createdAt DateTime         @default(now())

  classId   String
  class     Class  @relation(fields: [classId], references: [id])
  studentId String
  student   User   @relation("StudentAttendance", fields: [studentId], references: [id])
  teacherId String
  teacher   User   @relation("TeacherAttendance", fields: [teacherId], references: [id])

  @@unique([date, classId, studentId])
}

// ─── AI MODELS ────────────────────────────────────────────────────────────────

model ChatSession {
  id        String   @id @default(uuid())
  botType   BotType
  messages  Json     @default("[]") // [{role, content, timestamp}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentId  String
  student    User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  resourceId String?
  resource   Resource? @relation(fields: [resourceId], references: [id])
}

model StudyPlan {
  id        String   @id @default(uuid())
  planData  Json
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())

  studentId String
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event  @relation(fields: [eventId], references: [id])
}

// ─── AUTH MODELS ──────────────────────────────────────────────────────────────

model OTP {
  id        String   @id @default(uuid())
  userId    String
  otp       String
  purpose   String   // 'verify' | 'reset'
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
