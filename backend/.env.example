

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For Neon.tech: postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/educonnect

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-this
JWT_ACCESS_EXPIRES=30m
JWT_REFRESH_EXPIRES=7d

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production set this to your Vercel URL, e.g.: https://educonnect.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# ─── Cloudinary (file uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Use a Gmail address + App Password (NOT your real Gmail password).
# Steps: Enable 2FA → https://myaccount.google.com/apppasswords → create App Password
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password

# ─── Redis ────────────────────────────────────────────────────────────────────
# For Upstash free tier: rediss://default:TOKEN@host.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ─── Google OAuth (optional — leave blank to disable "Sign in with Google") ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# In production: https://your-backend.onrender.com/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ─── AI Service URL ───────────────────────────────────────────────────────────
# In production: https://your-ai-service.onrender.com
AI_SERVICE_URL=http://localhost:8000

BACKEND_URL=http://localhost:3000
